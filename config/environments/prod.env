# ============================================================
# TravelHub — Ambiente: PROD
# ============================================================
# Uso: source config/environments/prod.env && bash deploy-all.sh
#
# NOTA: Cloud Armor arranca SIN WAF para probar la infra.
# Solo rate limiting esta activo. Cuando quieras activar WAF,
# cambia ARMOR_WAF_ENABLED="true" y reejecuta 05-cloud-armor.sh.
# ============================================================
export ENV="prod"
export GCP_PROJECT_ID="travelhub-prod-492116"
export GCP_REGION="us-central1"
export DOMAIN="apitravelhub.site"

# Naming
export PREFIX="${ENV}-travelhub"
export VPC_NAME="${PREFIX}-vpc"
export CLOUD_ARMOR_POLICY="${PREFIX}-security-policy"
export DB_INSTANCE_NAME="${PREFIX}-db"
export DB_NAME="travelhub"
export DB_USER="travelhub_app"

# API Gateway
export API_GATEWAY_ID="${PREFIX}-api"
export API_GATEWAY_NAME="${PREFIX}-gateway"

# Load Balancer
export LB_IP_NAME="${PREFIX}-lb-ip"
export LB_NEG_NAME="${PREFIX}-gateway-neg"
export LB_BACKEND_NAME="${PREFIX}-backend-service"
export LB_URL_MAP_NAME="${PREFIX}-url-map"
export LB_CERT_NAME="${PREFIX}-ssl-cert"
export LB_PROXY_NAME="${PREFIX}-https-proxy"
export LB_FWD_RULE_NAME="${PREFIX}-forwarding-rule"

# SSL — self-signed para probar rapido; cambiar a "managed" cuando el DNS apunte a la IP
export SSL_MODE="self-signed"

# Networking
export SUBNET_PUBLIC_NAME="${PREFIX}-subnet-public"
export SUBNET_SERVICES_NAME="${PREFIX}-subnet-services"
export SUBNET_DATA_NAME="${PREFIX}-subnet-data"
export VPC_CONNECTOR_NAME="${PREFIX}-connector"
export PRIVATE_RANGE_NAME="${PREFIX}-private-range"

export SUBNET_PUBLIC_CIDR="10.20.1.0/24"
export SUBNET_SERVICES_CIDR="10.20.2.0/24"
export SUBNET_DATA_CIDR="10.20.3.0/24"
export VPC_CONNECTOR_CIDR="10.20.8.0/28"
export PRIVATE_RANGE_CIDR="10.200.0.0"
export PRIVATE_RANGE_PREFIX="20"

# Cloud SQL — config de prod
export DB_TIER="db-f1-micro"   # para pruebas; para prod real: db-custom-1-3840 o superior
export DB_HA="zonal"           # zonal para pruebas; para prod real: regional
export DB_BACKUP="true"
export DB_STORAGE="10GB"

# Cloud Armor
# Cloud Armor DESHABILITADO totalmente: el proyecto tiene quota SECURITY_POLICIES=0.
# Para activarlo:
#   1. Pide aumento de cuota en https://console.cloud.google.com/iam-admin/quotas
#      (filtra por SECURITY_POLICIES, pide 10)
#   2. Cambia CLOUD_ARMOR_ENABLED="true"
#   3. Re-ejecuta: bash scripts/05-cloud-armor.sh && bash scripts/08-load-balancer.sh
export CLOUD_ARMOR_ENABLED="false"
export ARMOR_WAF_ENABLED="false"
export ARMOR_GEO_BLOCK_ENABLED="false"

# Rate limits (se aplican aunque WAF este off)
export RATE_LIMIT_GLOBAL="500"
export RATE_LIMIT_LOGIN="50"
export RATE_LIMIT_PAYMENTS="100"

# Gateway
# Se completa despues del deploy de user-services
export JWKS_URI=""

# Microservicios Cloud Run (URLs se llenan post-deploy de cada servicio en prod)
export USER_SERVICES_URL=""
export SEARCH_SERVICES_URL=""
export BOOKING_SERVICES_URL=""
export PAYMENTS_SERVICES_URL=""
export INVENTORY_SERVICES_URL=""
export NOTIFICATION_SERVICES_URL=""
export PMS_SERVICES_URL=""
export CART_SERVICES_URL=""
